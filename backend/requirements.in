# SAM3 now uses transformers.Sam3Model directly. Do not install the old
# sam3==0.1.3 stack by default; it pulled extra packages (decord/hydra/iopath)
# that are not used by the current backend.
# Keep launcher installs visually clean when a reused Windows env already has
# selenium/trio from older dev/runtime packaging. Without these small runtime
# closure deps, pip prints scary resolver "ERROR" warnings after a successful
# install, which looks like app setup failed to normal users.
websocket-client>=1.8.0,<2.0
