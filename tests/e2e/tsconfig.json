{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["specs/**/*", "pages/**/*", "fixtures/**/*", "types/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
