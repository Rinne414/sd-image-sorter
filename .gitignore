# SD Image Sorter - .gitignore

# Python virtual environment
backend/venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment variables (user-specific configuration)
.env
.env.local
.env.*.local

# Requirements hash (auto-generated by launcher scripts)
backend/.requirements_hash

# Database (contains user-specific file paths)
backend/images.db
*.db

# ALL model files (auto-downloaded on first use, do NOT commit binaries)
models/wd14-tagger/
models/artist/
models/clip/
models/sam3/
models/nudenet/
models/aesthetic/
models/yolo/*.onnx
models/yolo/*.pt

# Embedded Python (generated by release script, not source)
python/
run-portable.bat
data/
update/

# Internal dev files (not for public repo)
AGENTS.md
CLAUDE.md
THIRD_PARTY_MODELS.md
SECURITY.md
backend/lora_debug.txt
example/
models/nudenet/

# Test images and personal folders (may contain personal images)
testimage/
backend/test-path/
backend/favorites/

# Output directories - ignore anywhere in repo (prevent accidental uploads!)
**/outputs/
**/censored_output/
outputs/
censored_output/

# Prevent any stray images in backend from being committed
backend/*.png
backend/*.jpg
backend/*.jpeg
backend/*.webp

# Debug and log files
*.log
backend/lora_debug.txt

# IDE files
.vscode/
.vs/
.idea/
*.swp
*.swo
.gemini/

# OS files
.DS_Store
Thumbs.db

# Mypy output files
mypy_*.txt

# Coverage and cache
.coverage
.coverage.*
coverage.xml
htmlcov/
backend/.coverage
backend/.coverage.*
backend/coverage.xml
backend/htmlcov/
backend/.mypy_cache/

# Thumbnail cache (runtime generated)
backend/thumbnails/
backend/sort_session.json

# Temp test directories
.tools/
.tmp/
.tmp_*/
.playwright-tmp-results/
.playwright-mcp/
test-results/
artifacts/
tests/e2e/node_modules/
tests/e2e/test-results/
tests/e2e/.pw-out/

# Loose test screenshots that sometimes get dropped at the repo root by
# ad-hoc playwright runs. Keep them out of git AND the release builder.
# Real product screenshots live under docs/screenshots/.
/e2e-*.png
/e2e-*.jpg
/e2e-*.jpeg
/e2e-*.webp
/playwright-*.png
/playwright-*.jpg
/playwright-*.jpeg
/playwright-*.webp
/screenshot-*.png
/screenshot-*.jpg
/test-*.png
/test-*.jpg

# Reference files (binaries, external tools)
reference/

# Internal planning docs
.plans/

# Claude Code internal
.claude/
.worktrees/

# Node.js (E2E testing infrastructure, root level)
node_modules/
package.json
package-lock.json

# ToriiGate model files (auto-downloaded, very large)
models/toriigate/

# Playwright persistent state
tests/e2e/storage/

# Dev-only scripts (not for distribution)
backend/fix_db_ratings.py
backend/test_censor_logic.py
backend/test_functionality.py
backend/test_images_thumbnail.py
backend/test_metadata_parser_params.py
backend/verify_sorting.py

# Internal docs (generated, not for public repo)
# docs/API.md is versioned because API contract tests validate it.
docs/DELETION_LOG.md
docs/IMPROVEMENT_PLAN.md
docs/SECURITY_ARCHITECTURE.md
docs/architecture.md

# Internal scratch / audit prompts (not for public repo)
v3_audit_prompt.md
v3-2-1.md
v[0-9]*-[0-9]*-[0-9]*.md

# Windows temp files
nul

# Optional local YOLO compatibility downloads (packaged via release assets, not source control)
models/yolo/civitai/
models/yolo/yolo26s-seg.onnx
models/yolo/yolo26s-seg.pt
models/yolo/yolov8s-seg.onnx
models/yolo/yolov8s-seg.pt
