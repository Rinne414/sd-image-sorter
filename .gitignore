# SD Image Sorter - .gitignore

# Python virtual environment
backend/venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment variables (user-specific configuration)
.env
.env.local
.env.*.local

# Requirements hash (auto-generated by launcher scripts)
backend/.requirements_hash

# Database (contains user-specific file paths)
backend/images.db
*.db

# ALL model files (auto-downloaded on first use, do NOT commit binaries)
models/wd14-tagger/
models/artist/
models/clip/
models/sam3/
models/nudenet/
models/yolo/*.onnx
models/yolo/*.pt

# Embedded Python (generated by release script, not source)
python/
run-portable.bat

# Internal dev files (not for public repo)
AGENTS.md
CLAUDE.md
THIRD_PARTY_MODELS.md
SECURITY.md
backend/lora_debug.txt
example/
models/nudenet/

# Test images and personal folders (may contain personal images)
testimage/
backend/test-path/
backend/favorites/

# Output directories - ignore anywhere in repo (prevent accidental uploads!)
**/outputs/
**/censored_output/
outputs/
censored_output/

# Prevent any stray images in backend from being committed
backend/*.png
backend/*.jpg
backend/*.jpeg
backend/*.webp

# Debug and log files
*.log
backend/lora_debug.txt

# IDE files
.vscode/
.vs/
.idea/
*.swp
*.swo
.gemini/

# OS files
.DS_Store
Thumbs.db

# Mypy output files
mypy_*.txt

# Coverage and cache
backend/.coverage
backend/.mypy_cache/

# Thumbnail cache (runtime generated)
backend/thumbnails/
backend/sort_session.json

# Temp test directories
.tmp/
.tmp_*/
.playwright-tmp-results/
test-results/
artifacts/
tests/e2e/node_modules/
tests/e2e/test-results/
tests/e2e/.pw-out/

# Reference files (binaries, external tools)
reference/

# Internal planning docs
.plans/

# Windows temp files
nul

# Optional local YOLO compatibility downloads (packaged via release assets, not source control)
models/yolo/civitai/
models/yolo/yolo26s-seg.onnx
models/yolo/yolo26s-seg.pt
models/yolo/yolov8s-seg.onnx
models/yolo/yolov8s-seg.pt
