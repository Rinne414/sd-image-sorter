# SD Image Sorter - .gitignore

# Python virtual environment
backend/venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Environment variables (user-specific configuration)
.env
.env.local
.env.*.local

# Requirements hash (auto-generated by launcher scripts)
backend/.requirements_hash

# Database (contains user-specific file paths)
backend/images.db
*.db

# Downloaded AI models (large files, auto-downloaded on first use)
models/wd14-tagger/

# Test images and personal folders (may contain personal images)
testimage/
backend/test-path/
backend/favorites/

# Output directories - ignore anywhere in repo (prevent accidental uploads!)
**/outputs/
**/censored_output/
outputs/
censored_output/

# Prevent any stray images in backend from being committed
backend/*.png
backend/*.jpg
backend/*.jpeg
backend/*.webp

# Debug and log files
*.log
backend/lora_debug.txt

# IDE files
.vscode/
.idea/
*.swp
*.swo
.gemini/

# OS files
.DS_Store
Thumbs.db

# Mypy output files
mypy_*.txt

# Coverage and cache
backend/.coverage
backend/.mypy_cache/

# Thumbnail cache (runtime generated)
backend/thumbnails/

# Temp test directories
.tmp_*/

# Reference files (binaries, external tools)
reference/

# Internal planning docs
.plans/

# Windows temp files
nul
