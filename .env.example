# SD Image Sorter Configuration
# Copy this file to .env and customize as needed.
# All settings can also be set via environment variables directly.

# =============================================================================
# Database Configuration
# =============================================================================

# Path to the SQLite database file
# Default: backend/images.db (relative to backend directory)
# SD_IMAGE_SORTER_DB_PATH=/path/to/custom/images.db

# Path to the favorites folder
# Default: backend/favorites
# SD_IMAGE_SORTER_FAVORITES_PATH=/path/to/favorites

# =============================================================================
# Server Configuration
# =============================================================================

# Server host address
# Default: 127.0.0.1 (localhost only, recommended for security)
# Use 0.0.0.0 to allow external connections (not recommended)
SD_IMAGE_SORTER_HOST=127.0.0.1

# Server port
# Default: 8000
SD_IMAGE_SORTER_PORT=8000

# =============================================================================
# Model Directories
# =============================================================================

# WD14 Tagger model storage directory
# Models will be downloaded here on first use
# Default: models/wd14-tagger (relative to project root)
# SD_IMAGE_SORTER_WD14_MODEL_DIR=/path/to/models/wd14-tagger

# YOLO censor model directory
# Default: models/yolo (relative to project root)
# SD_IMAGE_SORTER_YOLO_MODEL_DIR=/path/to/models/yolo

# Default cache directory (fallback for models)
# Default: ~/.cache/sd-image-sorter
# SD_IMAGE_SORTER_CACHE_DIR=/path/to/cache

# =============================================================================
# WD14 Tagger Configuration
# =============================================================================

# Default tagger model
# Options: wd-eva02-large-tagger-v3 (best quality), wd-swinv2-tagger-v3,
#          wd-convnext-tagger-v3, wd-vit-tagger-v3, wd-vit-large-tagger-v3
# Default: wd-eva02-large-tagger-v3
SD_IMAGE_SORTER_DEFAULT_TAGGER_MODEL=wd-eva02-large-tagger-v3

# Confidence threshold for general tags (0.0 - 1.0)
# Lower = more tags, Higher = fewer but more accurate tags
# Default: 0.35
SD_IMAGE_SORTER_TAGGER_GENERAL_THRESHOLD=0.35

# Confidence threshold for character tags (0.0 - 1.0)
# Character tags are typically harder to detect, hence higher threshold
# Default: 0.85
SD_IMAGE_SORTER_TAGGER_CHARACTER_THRESHOLD=0.85

# Enable GPU acceleration for tagging
# Set to "false" to force CPU-only mode (slower but more compatible)
# Default: true
SD_IMAGE_SORTER_TAGGER_USE_GPU=true

# =============================================================================
# Censor Configuration
# =============================================================================

# Default detection confidence threshold (0.0 - 1.0)
# Lower = more detections (more false positives)
# Higher = fewer detections (may miss some)
# Default: 0.60
SD_IMAGE_SORTER_CENSOR_CONFIDENCE=0.60

# IOU threshold for Non-Maximum Suppression (0.0 - 1.0)
# Controls overlapping box merging
# Default: 0.45
SD_IMAGE_SORTER_CENSOR_IOU_THRESHOLD=0.45

# Default mosaic block size (pixels)
# Larger = more pixelated, Smaller = finer mosaic
# Default: 16
SD_IMAGE_SORTER_CENSOR_BLOCK_SIZE=16

# Default blur radius (pixels)
# Larger = more blurred
# Default: 20
SD_IMAGE_SORTER_CENSOR_BLUR_RADIUS=20

# =============================================================================
# Similarity/CLIP Configuration
# =============================================================================

# CLIP embedding model name
# Default: Qdrant/clip-ViT-B-32-vision
# SD_IMAGE_SORTER_CLIP_MODEL=Qdrant/clip-ViT-B-32-vision

# Default number of similar images to return
# Default: 20
SD_IMAGE_SORTER_SIMILARITY_LIMIT=20

# Default similarity threshold (0.0 - 1.0)
# Higher = only very similar images
# Default: 0.5
SD_IMAGE_SORTER_SIMILARITY_THRESHOLD=0.5

# Duplicate detection threshold (0.0 - 1.0)
# Higher = stricter duplicate matching
# Default: 0.95
SD_IMAGE_SORTER_DUPLICATE_THRESHOLD=0.95

# =============================================================================
# Batch Processing
# =============================================================================

# Number of images to process per batch during tagging
# Lower = less memory usage, slower
# Higher = more memory usage, faster
# Default: 10
SD_IMAGE_SORTER_TAGGER_BATCH_SIZE=10

# Number of images to process per batch during embedding
# Default: 10
SD_IMAGE_SORTER_EMBEDDING_BATCH_SIZE=10

# Chunk size for duplicate detection matrix operations
# Lower = less memory, more iterations
# Higher = more memory, fewer iterations
# Default: 500
SD_IMAGE_SORTER_DUPLICATE_CHUNK_SIZE=500

# =============================================================================
# Path Validation (Security)
# =============================================================================

# Maximum path depth (number of directory levels)
# Prevents directory traversal attacks
# Default: 20
SD_IMAGE_SORTER_MAX_PATH_DEPTH=20

# Maximum path length (characters)
# Windows default: 260, Linux/macOS default: 4096
# SD_IMAGE_SORTER_MAX_PATH_LENGTH=260

# Maximum filename length for sanitization
# Default: 200
SD_IMAGE_SORTER_MAX_FILENAME_LENGTH=200

# =============================================================================
# Gallery/UI Defaults
# =============================================================================

# Default number of images per page in gallery
# Default: 100
SD_IMAGE_SORTER_GALLERY_LIMIT=100

# Maximum allowed gallery limit
# Set to prevent memory issues with huge libraries
# Default: 999999
# SD_IMAGE_SORTER_GALLERY_MAX_LIMIT=999999

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
SD_IMAGE_SORTER_LOG_LEVEL=INFO
